{
  "name": "claudesmith",
  "version": "0.2.2",
  "description": "Generate production-ready .claude folders from plain English. Agents, skills, orchestration — one command.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "claudesmith": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test dist/lib/__tests__/*.test.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agents",
    "skills",
    "orchestration",
    "cli",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "picocolors": "^1.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/therufet721/claudesmith.git"
  },
  "homepage": "https://github.com/therufet721/claudesmith#readme",
  "bugs": {
    "url": "https://github.com/therufet721/claudesmith/issues"
  }
}